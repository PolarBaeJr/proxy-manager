# --- Cloudflare (optional; enables the dashboard's DNS tab) ---
# Create a Cloudflare API token with Zone.DNS:Edit on the target zone.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=yourdomain.com

# --- Edge / TLS (only used with `--profile edge`) ---
# Comma-separated domains for Let's Encrypt autocert.
# Must already point at this host's public IP (port 80 reachable for ACME).
EDGE_DOMAINS=

# --- TLS cert probing (optional; surfaces cert expiry on the dashboard's Stats tab) ---
# Comma-separated SNI hostnames. The prober dials host.docker.internal:443 (i.e. nginx
# on the host) with each SNI and records the served origin cert's expiry + issuer.
# Format: "host.example.com" or "host.example.com@1.2.3.4:8443" to dial a custom target.
TLS_PROBE_TARGETS=
