# --- Cloudflare (optional; enables the dashboard's DNS tab) ---
# Create a Cloudflare API token with Zone.DNS:Edit on the target zone.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=yourdomain.com

# --- Edge / TLS (only used with `--profile edge`) ---
# Comma-separated domains for Let's Encrypt autocert.
# Must already point at this host's public IP (port 80 reachable for ACME).
EDGE_DOMAINS=
